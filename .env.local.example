NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://www.tamma.me

# Resend (email notifications — get key from https://resend.com)
RESEND_API_KEY=re_your_resend_api_key

# PayTech (get keys from https://paytech.sn dashboard)
PAYTECH_API_KEY=your_paytech_api_key
PAYTECH_API_SECRET=your_paytech_api_secret
PAYTECH_ENV=test

# Wave API (get keys from https://developers.wave.com)
WAVE_API_KEY=your_wave_api_key
WAVE_WEBHOOK_SECRET=your_wave_webhook_secret
WAVE_SIGNING_SECRET=your_wave_signing_secret

# Sentry (error tracking — get DSN from https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=lupandu
SENTRY_PROJECT=javascript-nextjs
